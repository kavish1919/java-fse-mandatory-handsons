<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback configuration for Exercise 12 — SLF4J Logging.

    Appenders:
      CONSOLE — coloured, human-readable output during development.
      FILE    — rolling daily file for persistent log storage.

    Root level: DEBUG (shows DEBUG, INFO, WARN, ERROR in the console).
    File level : INFO  (less verbose for stored logs).
-->
<configuration>

    <!-- ===================================================================
         CONSOLE APPENDER — colourised pattern for readability
         =================================================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) %cyan(%logger{36}) - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ===================================================================
         FILE APPENDER — rolling daily log file
         =================================================================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Roll over daily; keep 30 days of history -->
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
        <!-- File appender logs INFO and above -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- ===================================================================
         Logger configuration
         =================================================================== -->

    <!-- Application package: DEBUG and above -->
    <logger name="com.cognizant" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Root logger: INFO and above for all other libraries -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
